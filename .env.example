# Yerel geliştirme — üretim bağlantı bilgilerini buraya yazmayın
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nobelkurs"
# Neon: postgresql://...@ep-....neon.tech/neondb?sslmode=require
# İsteğe bağlı: adapter zorla (varsayılan: host'a göre otomatik)
# PRISMA_ADAPTER=pg
# PRISMA_ADAPTER=neon
PORT=3000
NODE_ENV=development

# Faz 7 — oturum (prod öncesi zorunlu)
AUTH_ENABLED=false
SESSION_SECRET="yerel-gelistirme-icin-rastgele-uzun-bir-metin"
ADMIN_PASSWORD_HASH=""

# Test veritabanı (integration testleri)
# DATABASE_URL_TEST="postgresql://postgres:postgres@localhost:5432/nobelkurs_test"

# PDF (Faz 6) — Puppeteer Chrome yolu (opsiyonel; varsayılan: postinstall ile indirilen)
# PUPPETEER_EXECUTABLE_PATH="C:/Program Files/Google/Chrome/Application/chrome.exe"
