<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <title><%= documentTitle %></title>
  <%- include('_pdf-styles') %>
</head>
<body>
  <% if (!pages.length) { %>
    <div class="pdf-page">
      <header class="pdf-header">
        <div class="pdf-header__brand"><%= appName %></div>
        <h1 class="pdf-header__title"><%= documentTitle %></h1>
      </header>
      <p class="pdf-empty"><%= emptyMessage %></p>
      <footer class="pdf-footer">Oluşturulma: <%= generatedAt %></footer>
    </div>
  <% } else { %>
    <% pages.forEach(function(page) { %>
      <div class="pdf-page">
        <header class="pdf-header">
          <div class="pdf-header__brand"><%= appName %></div>
          <h1 class="pdf-header__title"><%= page.heading %></h1>
          <% if (page.subheading) { %>
            <p class="pdf-header__meta"><%= page.subheading %></p>
          <% } %>
        </header>

        <%- include('_schedule-grid', { days, timeSlots, cellMap: page.cellMap }) %>

        <footer class="pdf-footer">Oluşturulma: <%= generatedAt %></footer>
      </div>
    <% }); %>
  <% } %>
</body>
</html>
