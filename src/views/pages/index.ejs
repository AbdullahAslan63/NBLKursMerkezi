<div class="page-header page-toolbar">
  <div>
    <h1>Haftalık Etüt Programı</h1>
    <p>Pazartesi – Pazar, tekrarlayan program</p>
  </div>
  <div class="page-toolbar__actions">
    <button type="button" class="btn btn--secondary" id="btn-export-master-pdf">Genel Programı İndir</button>
  </div>
</div>

<div class="stats-pills" aria-label="Özet istatistikler">
  <div class="stat-pill">
    <i data-lucide="calendar" class="stat-pill__icon"></i>
    <span class="stat-pill__value" id="stat-sessions"><%= stats.sessions %></span>
    <span class="stat-pill__label">etüt</span>
  </div>
  <div class="stat-pill">
    <i data-lucide="graduation-cap" class="stat-pill__icon"></i>
    <span class="stat-pill__value" id="stat-teachers"><%= stats.teachers %></span>
    <span class="stat-pill__label">öğretmen</span>
  </div>
  <div class="stat-pill">
    <i data-lucide="users" class="stat-pill__icon"></i>
    <span class="stat-pill__value" id="stat-students"><%= stats.students %></span>
    <span class="stat-pill__label">öğrenci</span>
  </div>
</div>

<%# ── Gün Seçici ── %>
<nav class="day-selector" aria-label="Gün seçici">
  <% days.forEach(function(day) { %>
    <button
      type="button"
      class="day-selector__pill<%= day.key === todayKey ? ' day-selector__pill--active day-selector__pill--today' : '' %>"
      data-day="<%= day.key %>"
      aria-pressed="<%= day.key === todayKey ? 'true' : 'false' %>"
    >
      <span class="day-selector__short"><%= day.short %></span>
      <span class="day-selector__full"><%= day.label %></span>
    </button>
  <% }); %>
</nav>

<%# ── Timeline Panelleri (her gün için bir tane, yalnızca aktif gün görünür) ── %>
<% days.forEach(function(day) { %>
  <div
    class="day-timeline<%= day.key === todayKey ? ' day-timeline--active' : '' %>"
    data-day="<%= day.key %>"
    role="region"
    aria-label="<%= day.label %> programı"
    <% if (day.key !== todayKey) { %>hidden<% } %>
  >
    <% const sessions = daySessionsMap[day.key]; %>
    <% if (sessions.length === 0) { %>
      <!-- Elegant Empty State -->
      <div class="agenda-empty-state">
        <div class="agenda-empty-state__icon-wrapper">
          <i data-lucide="calendar" class="agenda-empty-state__icon"></i>
        </div>
        <h3 class="agenda-empty-state__title">Planlanmış Etüt Yok</h3>
        <p class="agenda-empty-state__text">Bu gün için planlanmış herhangi bir etüt bulunmuyor.</p>
        <button type="button" class="btn btn--primary btn--center-add" style="margin-top: var(--space-4);" data-action="center-add-session">
          <i data-lucide="plus" class="btn--center-add__icon"></i>
          <span>Yeni Etüt Ekle</span>
        </button>
      </div>
    <% } else { %>
      <div class="agenda-timeline-container">
        <% 
          const timeGroups = [];
          sessions.forEach(function(session) {
            const timeKey = session.startTime + ' – ' + session.endTime;
            let group = timeGroups.find(g => g.timeKey === timeKey);
            if (!group) {
              group = { 
                timeKey: timeKey, 
                startTime: session.startTime, 
                endTime: session.endTime, 
                sessions: [] 
              };
              timeGroups.push(group);
            }
            group.sessions.push(session);
          });
        %>
        <% timeGroups.forEach(function(group) { %>
          <%- include('../partials/agenda-slot', {
            dayKey: day.key,
            group: group,
          }) %>
        <% }); %>
      </div>
    <% } %>
  </div>
<% }); %>

<%# ── Floating Action Button (FAB) ── %>
<button type="button" class="fab-btn" id="fab-add-session" aria-label="Yeni Etüt Ekle" data-tooltip="Yeni Etüt Ekle">
  <i data-lucide="plus" class="fab-btn__icon"></i>
</button>

<%# ── Modal (yapısal olarak aynı, sadece tetikleyici değişti) ── %>
<dialog id="schedule-modal" class="schedule-modal-dialog">
  <div class="schedule-modal-dialog__header">
    <button type="button" class="btn btn--secondary btn--icon" data-action="close-modal" aria-label="Kapat">✕</button>
  </div>
  <div id="schedule-modal-body" class="schedule-modal-dialog__body"></div>
</dialog>

<script type="module" src="/js/schedule.js"></script>
