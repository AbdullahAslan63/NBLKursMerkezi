<div class="page-header page-toolbar">
  <div>
    <h1>Öğretmenler</h1>
    <p>Etüt programına atanacak öğretmenleri yönetin</p>
  </div>
  <div class="page-toolbar__actions">
    <button type="button" class="btn btn--secondary" id="btn-export-pdf-teachers">PDF İndir</button>
    <button type="button" class="btn btn--primary" id="btn-add-teacher">Öğretmen Ekle</button>
  </div>
</div>

<div class="search-box page-search">
  <input type="search" id="teacher-search" placeholder="Öğretmen ara..." aria-label="Öğretmen ara">
</div>

<div id="teachers-empty" class="empty-state card" style="<%= teachers.length ? 'display:none' : '' %>">
  <h2>Henüz öğretmen yok</h2>
  <p>İlk öğretmeninizi ekleyerek etüt programını oluşturmaya başlayın.</p>
  <button type="button" class="btn btn--primary" data-action="add-teacher">Öğretmen Ekle</button>
</div>

<div id="teachers-table-wrap" style="<%= teachers.length ? '' : 'display:none' %>">
  <table class="data-table" id="teachers-table">
    <thead>
      <tr>
        <th>Ad</th>
        <th>Branş</th>
        <th>Etüt</th>
        <th class="col-actions">İşlem</th>
      </tr>
    </thead>
    <tbody id="teachers-tbody">
      <% teachers.forEach(function(t) { %>
        <tr data-id="<%= t.id %>" data-name="<%= t.name %>" data-subject="<%= t.subject %>" data-search="<%= (t.name + ' ' + (t.subject || '')).toLowerCase() %>">
          <td><%= t.name %></td>
          <td><span class="badge badge--subject"><%= t.subject || 'Belirtilmemiş' %></span></td>
          <td><span class="badge"><%= t.sessionCount %> etüt</span></td>
          <td class="col-actions">
            <button type="button" class="btn btn--secondary btn--icon" data-action="download-pdf" data-pdf-url="/pdf/teachers/<%= t.id %>" aria-label="PDF indir" data-tooltip="PDF indir">⬇</button>
            <button type="button" class="btn btn--secondary btn--icon" data-action="edit" aria-label="Düzenle" data-tooltip="Düzenle">✎</button>
            <button type="button" class="btn btn--secondary btn--icon" data-action="delete" aria-label="Sil" data-tooltip="Sil">✕</button>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<dialog id="teacher-modal" class="form-modal">
  <form id="teacher-form" method="dialog">
    <h2 id="teacher-modal-title">Öğretmen Ekle</h2>
    <div class="form-field">
      <label for="teacher-name">Ad Soyad</label>
      <input type="text" id="teacher-name" name="name" required autocomplete="off">
      <p class="form-field__error" id="teacher-name-error" hidden></p>
    </div>
    <div class="form-field">
      <label for="teacher-subject-select">Branş / Ders</label>
      <select id="teacher-subject-select" name="subjectSelect">
        <option value="">Seçiniz...</option>
        <option value="Matematik">Matematik</option>
        <option value="Geometri">Geometri</option>
        <option value="Fizik">Fizik</option>
        <option value="Kimya">Kimya</option>
        <option value="Biyoloji">Biyoloji</option>
        <option value="Türkçe">Türkçe</option>
        <option value="Edebiyat">Edebiyat</option>
        <option value="Tarih">Tarih</option>
        <option value="Coğrafya">Coğrafya</option>
        <option value="Felsefe">Felsefe</option>
        <option value="Din Kültürü">Din Kültürü</option>
        <option value="İngilizce">İngilizce</option>
      </select>
    </div>
    <div class="form-field">
      <label for="teacher-subject" style="font-size: 0.85rem; color: var(--color-text-muted); font-weight: normal; margin-top: 4px;">Listede yoksa yeni branş adı girin:</label>
      <input type="text" id="teacher-subject" name="subject" autocomplete="off" placeholder="örn. Bilişim">
    </div>
    <div class="form-modal__actions">
      <button type="button" class="btn btn--secondary" data-action="cancel">İptal</button>
      <button type="submit" class="btn btn--primary">Kaydet</button>
    </div>
  </form>
</dialog>

<script type="module" src="/js/teachers.js"></script>
